# ── Supabase ──────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Server ────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Branded Auth Email ────────────────────────────────────────
# Resend is used to send the branded Firebase magic-link email.
# Without this key, the backend logs the generated link for local testing.
RESEND_API_KEY=your-resend-api-key
AUTH_EMAIL_FROM=Sparx Bit <auth@your-domain.com>

# ── Firebase Admin ────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# JSON string from Firebase Console → Project settings → Service accounts.
# For deployment, prefer FIREBASE_SERVICE_ACCOUNT_BASE64 to avoid escaping JSON.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id"}
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
